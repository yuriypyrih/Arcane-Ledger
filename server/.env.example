PORT=3001
TRUST_PROXY_HOPS=0
MONGO_IMAGE=mongo:7.0
MONGO_CONTAINER_NAME=arcane-ledger-mongo
MONGO_PORT=27017
MONGO_DB_NAME=arcane_ledger
MONGO_INITDB_ROOT_USERNAME=ADMIN
MONGO_INITDB_ROOT_PASSWORD=PASS
MONGODB_URI="mongodb://${USERNAME}:${PASSWORD}@127.0.0.1:27017/arcane_ledger?authSource=admin"
DB_NAME=arcane_ledger
CORS_ALLOWED_ORIGINS=http://localhost:5174,http://127.0.0.1:5174,https://your-production-app.example.com
FRONTEND_URL=http://localhost:5174
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN_SECONDS=604800
AUTH_COOKIE_SECURE=false
EMAIL_VERIFICATION_TOKEN_EXPIRES_MINUTES=1440
PASSWORD_RESET_TOKEN_EXPIRES_MINUTES=10
RESEND_API_KEY=
RESEND_FROM_EMAIL="Arcane Ledger <no-reply@arcane-ledger.com>"
RESEND_REPLY_TO=arcane-ledger@hotmail.com
CHARACTER_AVATAR_S3_BUCKET=
CHARACTER_AVATAR_S3_REGION=
CHARACTER_AVATAR_S3_PUBLIC_BASE_URL=
CHARACTER_AVATAR_UPLOAD_MAX_BYTES=524288
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=
