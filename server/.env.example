# Server runtime
PORT=3001
TRUST_PROXY_HOPS=0
FRONTEND_URL=http://localhost:5174
CORS_ALLOWED_ORIGINS=http://localhost:5174,http://127.0.0.1:5174,https://your-production-app.example.com

# MongoDB
MONGO_INITDB_ROOT_USERNAME=ADMIN
MONGO_INITDB_ROOT_PASSWORD=PASS
MONGODB_URI="mongodb://${USERNAME}:${PASSWORD}@127.0.0.1:27017/arcane_ledger?authSource=admin"

# Auth
JWT_SECRET=replace-with-a-long-random-secret
AUTH_COOKIE_SECURE=false

# Email
RESEND_API_KEY=
RESEND_FROM_EMAIL="Arcane Ledger <no-reply@arcane-ledger.com>"
RESEND_REPLY_TO=arcane-ledger@hotmail.com

# Character avatars
CHARACTER_AVATAR_S3_BUCKET=
CHARACTER_AVATAR_S3_REGION=
CHARACTER_AVATAR_S3_PUBLIC_BASE_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Observability
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=
