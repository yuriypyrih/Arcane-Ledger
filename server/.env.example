PORT=3001
MONGO_IMAGE=mongo:7.0
MONGO_CONTAINER_NAME=dad-companion-mongo
MONGO_PORT=27017
MONGO_DB_NAME=dnd_companion
MONGO_INITDB_ROOT_USERNAME=ADMIN
MONGO_INITDB_ROOT_PASSWORD=PASS
MONGODB_URI=mongodb://ADMIN:PASS.0.0.1:27017/dnd_companion?authSource=admin
DB_NAME=dnd_companion
CORS_ALLOWED_ORIGINS=http://localhost:5174,http://127.0.0.1:5174,https://your-production-app.example.com
OPEN5E_BASE_URL=https://api.open5e.com
OPEN5E_MONSTERS_URL=https://api.open5e.com/monsters/?limit=100
OPEN5E_ITEMS_URL=https://api.open5e.com/v2/items/?limit=100
OPEN5E_REQUEST_DELAY_MS=200
OPEN5E_MONSTERS_ROOT_DIR=data/open5e/monsters
OPEN5E_ITEMS_ROOT_DIR=data/open5e/items
