{
  "name": "@arcane-ledger/server",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "db:docker:up": "docker compose -f docker-compose.mongodb.yml up -d",
    "db:docker:down": "docker compose -f docker-compose.mongodb.yml down",
    "db:docker:stop": "docker compose -f docker-compose.mongodb.yml stop",
    "db:docker:logs": "docker compose -f docker-compose.mongodb.yml logs -f mongodb",
    "db:docker:ps": "docker compose -f docker-compose.mongodb.yml ps"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1053.0",
    "@maxmind/geoip2-node": "^6.3.4",
    "@sentry/node": "^10.53.1",
    "argon2": "^0.44.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.1.0",
    "isbot": "^5.1.40",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.9.5",
    "resend": "^6.12.3"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.9.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
