{
  "name": "@dnd-companion/server",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "db:docker:up": "docker compose -f docker-compose.mongodb.yml up -d",
    "db:docker:down": "docker compose -f docker-compose.mongodb.yml down",
    "db:docker:stop": "docker compose -f docker-compose.mongodb.yml stop",
    "db:docker:logs": "docker compose -f docker-compose.mongodb.yml logs -f mongodb",
    "db:docker:ps": "docker compose -f docker-compose.mongodb.yml ps",
    "db:monsters:fetch": "tsx src/scripts/fetchOpen5eMonsters.ts",
    "db:monsters:import": "tsx src/scripts/importOpen5eMonsters.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.1",
    "helmet": "^8.1.0",
    "mongoose": "^8.9.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.9.0",
    "@types/supertest": "^6.0.3",
    "mongodb-memory-server": "^10.1.4",
    "supertest": "^7.0.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
